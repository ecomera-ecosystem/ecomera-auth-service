# ========================================
# Ecomera Auth Service Environment
# ========================================

# ---------------------------------------
# Server & Spring Configuration
# ---------------------------------------
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# ---------------------------------------
# Eureka & Config Server
# ---------------------------------------
EUREKA_SERVER_URL=http://localhost:8761/eureka/
EUREKA_HOSTNAME=localhost
CONFIG_SERVER_HOST=localhost
CONFIG_SERVER_PORT=8888

# ---------------------------------------
# Vault (secrets: db/password, jwt/signing-key)
# ---------------------------------------
VAULT_HOST=localhost
VAULT_PORT=8200
VAULT_TOKEN=hvs.xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------
# Database (password fetched from Vault)
# ---------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecomera_auth
DB_USERNAME=postgres
DDL_AUTO=none
SHOW_SQL=false
LIQUIBASE_ENABLED=true

# ---------------------------------------
# JWT (TTL from Vault, signing-key from Vault)
# ---------------------------------------
JWT_ACCESS_TTL=3600000
JWT_REFRESH_TTL=604800000
